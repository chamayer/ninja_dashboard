# ─────────────────────────────────────────────────────────────────────
# ninja-dashboard — environment variables
#
# Single source of truth — the host file at
#   /amr-ch-01_data/ninja-dashboard/.env
# is bind-mounted into every container that needs it:
#   - ingest    → /app/.env       (python-dotenv reads it)
#   - postgres  → /etc/secrets.env (entrypoint wrapper sources it)
#   - metabase  → /etc/secrets.env (entrypoint wrapper sources it)
#
# This sidesteps Portainer's git-deploy limitations (no ${VAR}
# substitution, no env_file: with absolute host paths). Bind-mounts
# are resolved by the docker daemon server-side, so they work even
# when Portainer's compose CLI can't see the host path.
#
# Values are NOT quoted — the source/dotenv parsers take values
# verbatim. For passwords, prefer `openssl rand -base64 24` which
# produces escape-safe characters. Avoid `$`, `#`, and backslashes.
#
# Setup on the host (am-ch-01):
#   sudo -i
#   mkdir -p /amr-ch-01_data/ninja-dashboard
#   cp .env.example /amr-ch-01_data/ninja-dashboard/.env
#   # edit with real values
#   chmod 600 /amr-ch-01_data/ninja-dashboard/.env
#
# .env is gitignored — do not commit real secrets.
# ─────────────────────────────────────────────────────────────────────

# ── Ninja API ────────────────────────────────────────────────────────
NINJA_BASE_URL=https://your-instance.rmmservice.com/v2
NINJA_TOKEN_URL=https://your-instance.rmmservice.com/ws/oauth/token
NINJA_CLIENT_ID=
NINJA_CLIENT_SECRET=
NINJA_SCOPE=monitoring

# ── Postgres (main app DB owned by ingest) ───────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ninja
POSTGRES_PASSWORD=
POSTGRES_DB=ninja

# ── Metabase app DB (separate database in the same Postgres) ─────────
# The init script in sql/init/00_create_databases.sh creates the
# `metabase` database and a `metabase` role using these values on
# first Postgres boot.
MB_DB_DBNAME=metabase
MB_DB_USER=metabase
MB_DB_PASS=

# ── Ingest behavior ──────────────────────────────────────────────────
# How often the ingest runs (hours).
INGEST_SCHEDULE_HOURS=1
# Optional override for the existing Ninja/patch ingest cadence. Empty
# means use INGEST_SCHEDULE_HOURS for backwards compatibility.
PATCH_INGEST_SCHEDULE_HOURS=
# Agent compliance is a separate domain/cadence. It reads Ninja data
# from the existing DB tables and collects S1/LMI/ScreenConnect from
# their native APIs when the matching platform_sources rows are enabled.
AGENT_COMPLIANCE_ENABLED=false
AGENT_COMPLIANCE_SCHEDULE_HOURS=4
# Log level: DEBUG | INFO | WARNING | ERROR
INGEST_LOG_LEVEL=INFO
# Bind address for the manual-trigger / healthcheck HTTP endpoint.
INGEST_HTTP_PORT=8090

# ── Activities filter ────────────────────────────────────────────────
# /v2/activities is high-volume. We filter aggressively.
#
# Source filter (server-side): comma-separated list of `sourceName`
# values to fetch. Default includes PATCH_MANAGEMENT plus SYSTEM (for
# SYSTEM_REBOOTED, which closes the loop on "did the post-patch reboot
# actually happen?").
INGEST_ACTIVITY_SOURCES=PATCH_MANAGEMENT,SYSTEM
#
# Type allowlist (client-side): comma-separated, exact-match. Empty =
# accept everything from the configured sources.
#
# Naming gotcha (verified against live API + Ninja API spec): Ninja's
# statusCode prefix is unreliable. The OS patching scan pair uses TWO
# different prefixes but both belong to OS patching (the human `status`
# text on each row is "OS Patching ..."):
#   - SOFTWARE_PATCH_MANAGEMENT_SCAN_STARTED → "OS Patching Scan Started"
#   - PATCH_MANAGEMENT_SCAN_COMPLETED       → "OS Patching Scan Complete"
# Both are paired via `seriesUid`. Trust the human `status` text over
# the SOFTWARE_ / PATCH_MANAGEMENT_ prefix.
#
# Deliberately EXCLUDED (all variants — both prefixes):
#   - *_INSTALLED / *_INSTALL_FAILED — these are NinjaRMM AGENT install
#     events for the patch-management module itself, NOT OS patches.
#     Operator-confirmed.
#   - PATCH_MANAGEMENT_SCAN_STARTED — documented in API spec but not
#     emitted by current Ninja agent; filter is silently ignored and
#     returns unfiltered activities. Use SOFTWARE_PATCH_MANAGEMENT_-
#     SCAN_STARTED instead.
INGEST_ACTIVITY_TYPES_INCLUDE=PATCH_MANAGEMENT_APPLY_PATCH_STARTED,PATCH_MANAGEMENT_APPLY_PATCH_COMPLETED,PATCH_MANAGEMENT_MESSAGE,PATCH_MANAGEMENT_FAILURE,PATCH_MANAGEMENT_ROLLBACK_PATCH_REQUESTED,PATCH_MANAGEMENT_ROLLBACK_PATCH_STARTED,PATCH_MANAGEMENT_ROLLBACK_PATCH_COMPLETED,PATCH_MANAGEMENT_PATCH_APPROVED,PATCH_MANAGEMENT_PATCH_REJECTED,PATCH_MANAGEMENT_SCAN_COMPLETED,SOFTWARE_PATCH_MANAGEMENT_SCAN_STARTED,SOFTWARE_PATCH_MANAGEMENT_MESSAGE,SYSTEM_REBOOTED

# ── Custom fields filter ─────────────────────────────────────────────
# Empty (default) = ingest EVERY scoped custom field on device,
# organization, and location records, including system noise
# (rebootReason can be 20k+ chars of HTML per device).
# Strongly recommended: set an explicit allowlist of just the fields
# your dashboards actually need. Use the probe to discover what's
# available on your instance:
#   docker exec ninja-ingest python -m ingest.probe \
#     /queries/scoped-custom-fields --pages 1 --page-size 5 --full
# Example:
#   INGEST_CUSTOM_FIELDS_INCLUDE=patchingDisabled,patchingNotes,rds,wsusSettings
#   INGEST_CUSTOM_FIELDS_INCLUDE=patchingDisabled,patchingEnabled,patchingNotes,rds,wsusSettings
INGEST_CUSTOM_FIELDS_INCLUDE=

# Hard cap on value_text length per cell. Anything longer is truncated
# with a marker. Defends against multi-KB values polluting the table
# regardless of allowlist setting.
INGEST_CUSTOM_FIELDS_MAX_TEXT=4000

# Optional allowlist of policy names that should count as patching-enabled
# for servers. Leave empty to require a device override instead.
# Example:
#   INGEST_PATCHING_ENABLED_POLICIES=RDS,Server-Patching,Windows Servers
INGEST_PATCHING_ENABLED_POLICIES=

# ── Dashboard view filters ───────────────────────────────────────────
# Comma-separated patch category types (Ninja's `type` value) to hide
# from every patch-context dashboard query. Empty = show all.
# Known Ninja categories: UNKNOWN, UNSPECIFIED, DRIVER_UPDATES,
# SECURITY_UPDATES, UPDATE_ROLLUPS, CRITICAL_UPDATES, REGULAR_UPDATES,
# DEFINITION_UPDATES, FEATURE_UPDATES, SERVICE_PACKS, FEATURE_PACKS.
# Filtering happens in dashboard SQL only — raw rows stay in
# patch_facts so flipping the var back in is a one-line change.
DASHBOARD_PATCH_CATEGORIES_EXCLUDE=DRIVER_UPDATES

# ── Agent compliance source secrets ─────────────────────────────────
# Non-secret source config lives in Postgres
# (ninja_agent_compliance.platform_sources). These env vars hold the
# referenced secret values only.
#
# SentinelOne shared source example:
#   platform_sources.base_url = https://usea1-example.sentinelone.net/web/api/v2.1
#   platform_sources.api_token_secret_ref = S1_MAIN_API_TOKEN
S1_MAIN_API_TOKEN=
#
# LogMeIn shared source example:
#   platform_sources.base_url = https://secure.logmein.com/public-api
#   platform_sources.company_id_secret_ref = LMI_MAIN_COMPANY_ID
#   platform_sources.psk_secret_ref = LMI_MAIN_PSK
LMI_MAIN_COMPANY_ID=
LMI_MAIN_PSK=
#
# ScreenConnect is per client/tenant. Add one set per enabled source.
#   platform_sources.ext_guid_secret_ref = SC_UTA_EXT_GUID
#   platform_sources.secret_key_secret_ref = SC_UTA_SECRET_KEY
SC_UTA_EXT_GUID=
SC_UTA_SECRET_KEY=

# ── Agent compliance alerting ───────────────────────────────────────
AGENT_COMPLIANCE_ALERTS_ENABLED=false
AGENT_COMPLIANCE_ALERT_COOLDOWN_HOURS=24
AGENT_COMPLIANCE_ALERT_WEBHOOK_URL=
#
# Email route. Enable the `default_email` notification route in DB and
# point alert_rules.route_id at it when ready.
AGENT_COMPLIANCE_ALERT_EMAIL_FROM=
AGENT_COMPLIANCE_ALERT_EMAIL_TO=
AGENT_COMPLIANCE_SMTP_HOST=
AGENT_COMPLIANCE_SMTP_PORT=587
AGENT_COMPLIANCE_SMTP_USERNAME=
AGENT_COMPLIANCE_SMTP_PASSWORD=
AGENT_COMPLIANCE_SMTP_STARTTLS=true
#
# Zendesk requests route. Enable the `default_zendesk` route in DB and
# point alert_rules.route_id at it when ready. URL may be the base tenant
# URL (https://amrose.zendesk.com) or the full /api/v2/requests path.
AGENT_COMPLIANCE_ZENDESK_URL=
AGENT_COMPLIANCE_ZENDESK_REQUESTER_EMAIL=
AGENT_COMPLIANCE_ZENDESK_REQUESTER_NAME=Agent Compliance
AGENT_COMPLIANCE_ZENDESK_AUTH_USERNAME=
AGENT_COMPLIANCE_ZENDESK_AUTH_TOKEN=

# ── Metabase auto-bootstrap (optional) ───────────────────────────────
# If both MB_BOOTSTRAP_USER and MB_BOOTSTRAP_PASS are set, the ingest
# container runs the dashboard bootstrap automatically on startup
# (idempotent — safe to re-run on every Portainer redeploy). Leave
# empty to opt out and run manually instead:
#   docker exec -it ninja-ingest python -m ingest.metabase_bootstrap \
#       --user you@example.com
#
# These are the Metabase ADMIN account created in the first-run wizard
# — NOT the Postgres credentials.
MB_BOOTSTRAP_URL=http://metabase:3000
MB_BOOTSTRAP_USER=
MB_BOOTSTRAP_PASS=
MB_BOOTSTRAP_DB_NAME=Ninja
