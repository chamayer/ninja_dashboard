# ─────────────────────────────────────────────────────────────────────
# ninja-dashboard — environment variables
#
# Live deployment loads this from a HOST PATH (not next to compose):
#   /amr-ch-01_data/ninja-dashboard/.env
#
# Two channels read it, both resolved server-side by the Docker daemon
# (so Portainer doesn't need access to the host path):
#   1. `env_file:` on every service in docker-compose.yml — values are
#      injected into each container's environment at start.
#   2. A bind-mount into the ingest container at /app/.env as a fallback
#      for manual `docker exec` invocations of `python -m ingest.smoke`.
#
# Values are NOT quoted. Compose env_file takes values verbatim — quotes
# would end up in the value. For passwords, prefer `openssl rand -base64 24`
# which produces escape-safe characters. Avoid `$`, `#`, and backslashes.
#
# Setup on the host (am-ch-01):
#   sudo -i
#   mkdir -p /amr-ch-01_data/ninja-dashboard
#   cp .env.example /amr-ch-01_data/ninja-dashboard/.env
#   # edit with real values
#   chmod 600 /amr-ch-01_data/ninja-dashboard/.env
#
# .env is gitignored — do not commit real secrets.
# ─────────────────────────────────────────────────────────────────────

# ── Ninja API ────────────────────────────────────────────────────────
NINJA_BASE_URL=https://your-instance.rmmservice.com/v2
NINJA_TOKEN_URL=https://your-instance.rmmservice.com/ws/oauth/token
NINJA_CLIENT_ID=
NINJA_CLIENT_SECRET=
NINJA_SCOPE=monitoring

# ── Postgres (main app DB owned by ingest) ───────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ninja
POSTGRES_PASSWORD=
POSTGRES_DB=ninja

# ── Metabase app DB (separate database in the same Postgres) ─────────
# The init script in sql/init/00_create_databases.sh creates the
# `metabase` database and a `metabase` role using these values on
# first Postgres boot.
MB_DB_DBNAME=metabase
MB_DB_USER=metabase
MB_DB_PASS=

# ── Ingest behavior ──────────────────────────────────────────────────
# How often the ingest runs (hours).
INGEST_SCHEDULE_HOURS=1
# Log level: DEBUG | INFO | WARNING | ERROR
INGEST_LOG_LEVEL=INFO
# Bind address for the manual-trigger / healthcheck HTTP endpoint.
INGEST_HTTP_PORT=8090

# ── Activities filter ────────────────────────────────────────────────
# /v2/activities is high-volume. We filter aggressively.
#
# Source filter (server-side): comma-separated list of `sourceName`
# values to fetch. Default includes PATCH_MANAGEMENT plus SYSTEM (for
# SYSTEM_REBOOTED, which closes the loop on "did the post-patch reboot
# actually happen?").
INGEST_ACTIVITY_SOURCES=PATCH_MANAGEMENT,SYSTEM
#
# Type allowlist (client-side): comma-separated, exact-match. Empty =
# accept everything from the configured sources. Default = patch
# application + lifecycle, deliberately excluding:
#   - PATCH_MANAGEMENT_SCAN_STARTED / _COMPLETED — scanning, noisy,
#     no reporting value.
#   - PATCH_MANAGEMENT_INSTALLED / _INSTALL_FAILED — these are about
#     the patch-management AGENT being installed on a device, not OS
#     patches being applied. Rare events, not relevant to patch
#     reporting. The actual patch-application events are
#     PATCH_MANAGEMENT_APPLY_PATCH_*.
INGEST_ACTIVITY_TYPES_INCLUDE=PATCH_MANAGEMENT_APPLY_PATCH_STARTED,PATCH_MANAGEMENT_APPLY_PATCH_COMPLETED,PATCH_MANAGEMENT_MESSAGE,PATCH_MANAGEMENT_FAILURE,PATCH_MANAGEMENT_ROLLBACK_PATCH_REQUESTED,PATCH_MANAGEMENT_ROLLBACK_PATCH_STARTED,PATCH_MANAGEMENT_ROLLBACK_PATCH_COMPLETED,PATCH_MANAGEMENT_PATCH_APPROVED,PATCH_MANAGEMENT_PATCH_REJECTED,SYSTEM_REBOOTED
